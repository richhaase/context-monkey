{
  "name": "context-monkey",
  "version": "0.1.0",
  "description": "Make AI agent harness configurations portable — scan, diff, and sync context between Claude Code, Codex, Gemini, Cursor, Copilot, and more",
  "keywords": [
    "ai",
    "agent",
    "context",
    "portable",
    "claude",
    "codex",
    "gemini",
    "cursor",
    "copilot",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/richhaase/context-monkey.git"
  },
  "author": "Rich Haase",
  "type": "module",
  "bin": {
    "context-monkey": "src/index.ts",
    "cm": "src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "test": "bun test",
    "check": "tsc --noEmit && biome check src/ && bun test",
    "lint": "biome check src/",
    "fmt": "biome check --write src/"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "chalk": "^5.4.0",
    "commander": "^14.0.0"
